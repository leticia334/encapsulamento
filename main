public class Main {

    public static void main(String[] args) {

        Aluno aluno = new Aluno("Carlos", 16, "Informática");

        Professor professora =
                new Professor("Ana", 35, "Matemática");

        Funcionario funcionario =
                new Funcionario("João", 40, "Secretário");

        Responsavel responsavel =
                new Responsavel("Maria", 45, "Mãe");

        Pessoa pessoa =
                new Pessoa("Pedro", 20);

        aluno.apresentacao();
        professora.apresentacao();
        funcionario.apresentacao();
        responsavel.apresentacao();
        pessoa.apresentacao();

        System.out.println("-----------");

        aluno.saudacao(aluno);

        professora.saudacao(professora);

        funcionario.saudacao(funcionario);

        responsavel.saudacao(responsavel);

        pessoa.saudacao(aluno);
    }
}
