class Aluno extends Pessoa {
    String matricula;

    Aluno(String nome, String fone, String cpf, String matricula) {
        super(nome, fone, cpf);
        this.matricula = matricula;
    }

    String aprende() {
        return nome + " está aprendendo.";
    }

    @Override
    String saudacao() {
        return "Olá aluno " + nome;
    }
}
