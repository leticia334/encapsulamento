class Professor extends Aluno {
    String titulo;

    Professor(String nome, String fone, String cpf,
               String matricula, String titulo) {

        super(nome, fone, cpf, matricula);
        this.titulo = titulo;
    }

    String ensina() {
        return nome + " está ensinando.";
    }

    @Override
    String saudacao() {
        return "Olá professor " + nome;
    }
}
