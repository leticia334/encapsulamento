public class Responsavel extends Pessoa {

    private String parentesco;

    public Responsavel(String nome, int idade, String parentesco) {
        super(nome, idade);
        this.parentesco = parentesco;
    }

    public String getParentesco() {
        return parentesco;
    }

    public void setParentesco(String parentesco) {
        this.parentesco = parentesco;
    }

    @Override
    public void apresentacao() {
        System.out.println("Olá, eu sou o responsável " + getNome());
    }

    public void saudacao(Responsavel responsavel) {
        System.out.println("Prazer em conhecer o responsável "
                + responsavel.getNome());
    }
}
